      "options": {
        "cwd": "${workspaceFolder}/client"
      }
    },
    {
      "label": "🔨 Build Admin Dashboard (Production)",
      "type": "shell",
      "command": "npm run build",
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "close": false
      },
      "options": {
        "cwd": "${workspaceFolder}/admin-dashboard"
      }
    }
