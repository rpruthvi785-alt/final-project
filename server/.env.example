PORT=5001

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Option A: MongoDB Atlas (cloud) — recommended for production / sharing
#   1. Create a free cluster at https://cloud.mongodb.com
#   2. Go to Network Access → Add IP Address → Allow Access from Anywhere (0.0.0.0/0)
#   3. Paste your connection string below:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/travel-trackers?retryWrites=true&w=majority&appName=Cluster0

# Option B: Local MongoDB — if you have MongoDB installed on this PC
# MONGO_URI=mongodb://localhost:27017/travel-trackers

# Option C: Leave blank — app will use an in-memory database automatically (data resets on restart)
MONGO_URI=mongodb://localhost:27017/travel-trackers

# ── Authentication ────────────────────────────────────────────────────────────
# Change this to any long random string (keep it secret!)
JWT_SECRET=travel_trackers_super_secret_key_change_me_in_production
JWT_EXPIRE=7d

# ── Cloudinary (image uploads) ────────────────────────────────────────────────
# Get free credentials at https://cloudinary.com
# Leave as "demo" to use Cloudinary's public demo account (limited)
CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=demo
CLOUDINARY_API_SECRET=demo

# ── Client URLs ───────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Email (password reset / notifications) ───────────────────────────────────
# For Gmail: enable 2FA and use an App Password (not your real password)
# See: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
